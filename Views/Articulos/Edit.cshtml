@model ProyectoTema3.Models.Articulo

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Editar Artículo";
}

<div class="form-section">
    <div class="section-header">
        <h2>✏️ Editar Artículo</h2>
    </div>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-error">@ViewBag.Error</div>
    }

    @using (Html.BeginForm("Edit", "Articulos", new { id = Model.IdArticulo }, FormMethod.Post, new { @class = "form" }))
    {
        @Html.AntiForgeryToken()
        @Html.HiddenFor(m => m.IdArticulo)

        <div class="form-group">
            @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-input" })
            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "error-message" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Descripcion, new { @class = "form-label" })
            @Html.TextAreaFor(m => m.Descripcion, new { @class = "form-textarea", @rows = "4" })
        </div>

        <div class="form-row">
            <div class="form-group">
                @Html.LabelFor(m => m.Precio, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Precio, new { @class = "form-input", @type = "number", @step = "0.01" })
                @Html.ValidationMessageFor(m => m.Precio, "", new { @class = "error-message" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Stock, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Stock, new { @class = "form-input", @type = "number" })
                @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "error-message" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Categoria, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Categoria, new { @class = "form-input" })
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">💾 Guardar Cambios</button>
            <a href="@Url.Action("Index", "Articulos")" class="btn btn-secondary">Cancelar</a>
        </div>
    }
</div>
