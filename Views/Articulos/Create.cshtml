@model ProyectoTema3.Models.Articulo

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewBag.Title = "Crear Artículo";
}

<div class="form-section">
    <div class="section-header">
        <h2>➕ Crear Nuevo Artículo</h2>
    </div>

    @using (Html.BeginForm("Create", "Articulos", FormMethod.Post, new { @class = "form" }))
    {
        @Html.AntiForgeryToken()

        <div class="form-group">
            @Html.LabelFor(m => m.Nombre, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Nombre, new { @class = "form-input", @placeholder = "Ej: Laptop Dell" })
            @Html.ValidationMessageFor(m => m.Nombre, "", new { @class = "error-message" })
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Descripcion, new { @class = "form-label" })
            @Html.TextAreaFor(m => m.Descripcion, new { @class = "form-textarea", @placeholder = "Descripción del artículo", @rows = "4" })
        </div>

        <div class="form-row">
            <div class="form-group">
                @Html.LabelFor(m => m.Precio, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Precio, new { @class = "form-input", @placeholder = "0.00", @type = "number", @step = "0.01" })
                @Html.ValidationMessageFor(m => m.Precio, "", new { @class = "error-message" })
            </div>

            <div class="form-group">
                @Html.LabelFor(m => m.Stock, new { @class = "form-label" })
                @Html.TextBoxFor(m => m.Stock, new { @class = "form-input", @placeholder = "0", @type = "number" })
                @Html.ValidationMessageFor(m => m.Stock, "", new { @class = "error-message" })
            </div>
        </div>

        <div class="form-group">
            @Html.LabelFor(m => m.Categoria, new { @class = "form-label" })
            @Html.TextBoxFor(m => m.Categoria, new { @class = "form-input", @placeholder = "Ej: Electrónica" })
        </div>

        <div class="form-actions">
            <button type="submit" class="btn btn-primary">💾 Guardar Artículo</button>
            <a href="@Url.Action("Index", "Articulos")" class="btn btn-secondary">Cancelar</a>
        </div>
    }
</div>
